import cv2
import numpy as np
import sys

# Mappa colori → punteggio
COLOR_VALUES = {
    "black": -2,
    "red":   -1,
    "yellow": 0,
    "green":  1,
    "blue":   2,
}

def prepara_riferimenti_hsv():
    """
    Crea i colori di riferimento (nero, rosso, giallo, verde, blu)
    in HSV, partendo da BGR ideali.
    """
    ref_bgr = {
        "black":  (0,   0,   0),
        "red":    (0,   0, 255),
        "yellow": (0, 255, 255),
        "green":  (0, 255,   0),
        "blue":   (255, 0,   0),
    }

    ref_hsv = {}
    for name, bgr in ref_bgr.items():
        sample = np.uint8([[bgr]])          # immagine 1x1
        hsv = cv2.cvtColor(sample, cv2.COLOR_BGR2HSV)[0, 0]
        ref_hsv[name] = hsv.astype(np.float32)
    return ref_hsv

REF_HSV = prepara_riferimenti_hsv()


def classifica_colore(bgr_color):
    """
    Dato un colore medio in BGR, lo converte in HSV e
    lo assegna al colore più vicino tra:
    black, red, yellow, green, blue
    usando distanza euclidea nello spazio HSV.
    """
    sample = np.uint8([[bgr_color]])
    hsv = cv2.cvtColor(sample, cv2.COLOR_BGR2HSV)[0, 0].astype(np.float32)

    best_name = None
    best_dist = float("inf")
    for name, ref in REF_HSV.items():
        # piccola correzione per l'angolo H del rosso (0/180) se serve
        diff = hsv - ref
        # per il canale H gestiamo il wrap (0-180)
        diff[0] = min(abs(diff[0]), 180 - abs(diff[0]))
        dist = np.linalg.norm(diff)
        if dist < best_dist:
            best_dist = dist
            best_name = name

    return best_name

