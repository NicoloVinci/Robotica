# versione più potente con identificazione cerchio più grande, funziona con immagini png
def trova_cerchio_esterno(gray):
        
    h, w = gray.shape[:2]

    # 1. CLAHE
    clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8,8))
    gray_eq = clahe.apply(gray)

    # 2. Blur
    blur = cv2.GaussianBlur(gray_eq, (5,5), 0)

    # 3. Maschera anti-bordo
    mask = np.zeros((h, w), dtype=np.uint8)
    cv2.circle(mask, (w//2, h//2), int(min(h,w)*0.48), 255, -1)
    masked = cv2.bitwise_and(blur, blur, mask=mask)

    # 4. Canny adattivo
    v = np.median(masked)
    low = int(max(0, 0.66 * v))
    high = int(min(255, 1.33 * v))
    edges = cv2.Canny(masked, low, high)

    # 5. Hough con range realistico
    minR = int(min(h, w) * 0.30)
    maxR = int(min(h, w) * 0.55)

    circles = cv2.HoughCircles(
        edges,
        cv2.HOUGH_GRADIENT,
        dp=1.2,
        minDist=200,
        param1=100,
        param2=20,
        minRadius=minR,
        maxRadius=maxR
    )

    if circles is not None:
        circles = np.uint16(np.around(circles[0, :]))
        outer = max(circles, key=lambda c: c[2])
        return int(outer[0]), int(outer[1]), int(outer[2])

    # 6. Fallback: fit geometrico
    cnts, _ = cv2.findContours(edges, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    cnts = [c for c in cnts if cv2.contourArea(c) > 5000]

    best_circle = None
    best_radius = 0

    for c in cnts:
        (x, y), r = cv2.minEnclosingCircle(c)
        if r > best_radius:
            best_radius = r
            best_circle = (int(x), int(y), int(r))

    return best_circle



def calcola_punteggio_immagine(path_img, mostra_debug:bool):
    """
    Carica l'immagine, rileva i 5 anelli concentrici, classifica il colore di ciascuno,
    calcola i punti totali e stampa il risultato.

    Ritorna: (lista_colori, lista_valori, somma)
    """
    img = cv2.imread(path_img)
    if img is None:
        raise FileNotFoundError(f"Impossibile aprire l'immagine: {path_img}")

    h, w = img.shape[:2]
    print( img.shape )
    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)

    # Trova il cerchio esterno
    cx, cy, r_outer = trova_cerchio_esterno(gray)
    #centro del cerchio esterno e raggio
    print(f"Centro cerchio {cx, cy}, raggio esterno {r_outer}:")

    # Se vogliamo vedere il centro/cerchio (debug)
    if mostra_debug:
        dbg = img.copy()
        cv2.circle(dbg, (cx, cy), r_outer, (0, 255, 0), 2)
        cv2.circle(dbg, (cx, cy), 2, (0, 0, 25), 3)
        cv2.imshow("Debug cerchio esterno", dbg)
        cv2.waitKey(0)
        cv2.destroyAllWindows()

    colors = []
    values = []

    # Dividiamo il raggio in 5 anelli uguali (misure sono in pixel)
    step = r_outer / 5.0
    print(f"step anelli: {step}")
    for i in range(5):
        inner_r = int(i * step)
        outer_r = int((i + 1) * step) - 1
        print(f"Anello {i+1}: raggio interno {inner_r}, raggio esterno {outer_r}")

        # maschera dell'anello
        mask_outer = np.zeros((h, w), dtype=np.uint8)
        mask_inner = np.zeros((h, w), dtype=np.uint8)

        cv2.circle(mask_outer, (cx, cy), outer_r, 255, thickness=-1)
        cv2.circle(mask_inner, (cx, cy), inner_r, 255, thickness=-1)

        ring_mask = cv2.subtract(mask_outer, mask_inner)

        # media del colore BGR dentro l'anello
        mean_b, mean_g, mean_r, _ = cv2.mean(img, mask=ring_mask)
        mean_color = (mean_b, mean_g, mean_r)

        color_name = classifica_colore(mean_color)
        value = COLOR_VALUES[color_name]

        colors.append(color_name)
        values.append(value)

    total = sum(values)

    # Stampa risultati in stile “regole”
    print("Risultati analisi immagine:", path_img)
    print("Anelli dal centro verso l’esterno:")
    for i, (c, v) in enumerate(zip(colors, values), start=1):
        print(f"  Anello {i}: {c}  → valore {v}")

    print(f"\nSomma totale: {total}")

    # Interpretazione secondo regole RoboCup
    if total == 0:
        print("→ Bersaglio valido: Sum = 0 (solo identificazione, LED e stop 5s).")
    elif total == 1:
        print("→ Bersaglio valido: Sum = 1 (identificazione + 1 kit di soccorso).")
    elif total == 2:
        print("→ Bersaglio valido: Sum = 2 (identificazione + 2 kit di soccorso).")
    else:
        print("→ Bersaglio FALSO: Sum < 0 oppure > 2 (misidentificazione → -5 punti).")

    return colors, values, total


if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Uso: python cognitive_target_score.py immagine.png")
        sys.exit(1)

    img_path = sys.argv[1]
    calcola_punteggio_immagine(img_path, mostra_debug=True)
